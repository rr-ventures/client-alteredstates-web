{
  "name": "client-alteredstates-web",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspace/client-alteredstates-web",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/client-alteredstates-web,type=bind,consistency=cached",
  "postCreateCommand": "npm run install:all",
  "forwardPorts": [8080, 8081, 4173, 4174],
  "portsAttributes": {
    "8080": {
      "label": "Vite — Lovable",
      "onAutoForward": "notify"
    },
    "8081": {
      "label": "Vite — Bolt",
      "onAutoForward": "notify"
    },
    "4173": {
      "label": "Vite preview — Lovable",
      "onAutoForward": "silent"
    },
    "4174": {
      "label": "Vite preview — Bolt",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-vscode-remote.remote-containers",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
